<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <TCEforms>
                    <sheetTitle>General</sheetTitle>
                </TCEforms>
                <type>array</type>
                <el>
                    <settings.discoverableEnabled>
                        <TCEforms>
                            <label>Enable discoverable login (no username required)</label>
                            <config>
                                <type>check</type>
                                <renderType>checkboxToggle</renderType>
                                <items type="array">
                                    <numIndex index="0" type="array">
                                        <numIndex index="0"></numIndex>
                                        <numIndex index="1">0</numIndex>
                                    </numIndex>
                                </items>
                                <default>1</default>
                            </config>
                        </TCEforms>
                    </settings.discoverableEnabled>
                    <settings.showPasswordFallback>
                        <TCEforms>
                            <label>Show password fallback link</label>
                            <config>
                                <type>check</type>
                                <renderType>checkboxToggle</renderType>
                                <items type="array">
                                    <numIndex index="0" type="array">
                                        <numIndex index="0"></numIndex>
                                        <numIndex index="1">0</numIndex>
                                    </numIndex>
                                </items>
                                <default>1</default>
                            </config>
                        </TCEforms>
                    </settings.showPasswordFallback>
                    <settings.redirectAfterLogin>
                        <TCEforms>
                            <label>Redirect after login</label>
                            <config>
                                <type>group</type>
                                <allowed>pages</allowed>
                                <size>1</size>
                                <maxitems>1</maxitems>
                                <minitems>0</minitems>
                            </config>
                        </TCEforms>
                    </settings.redirectAfterLogin>
                    <settings.cssClass>
                        <TCEforms>
                            <label>CSS class override</label>
                            <config>
                                <type>input</type>
                                <size>30</size>
                                <eval>trim</eval>
                            </config>
                        </TCEforms>
                    </settings.cssClass>
                </el>
            </ROOT>
        </sDEF>
    </sheets>
</T3DataStructure>
