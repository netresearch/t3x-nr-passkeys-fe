#!/bin/bash

## Description: Install TYPO3 14.x with nr_passkeys_fe extension
## Usage: install-v14
## Example: ddev install-v14

set -e

VERSION=v14
INSTALL_DIR="/var/www/html/$VERSION"
FE_EXTENSION_PATH="/var/www/nr_passkeys_fe"
BE_EXTENSION_PATH="/var/www/nr_passkeys_be"
SITE_URL="https://${VERSION}.nr-passkeys-fe.ddev.site"

echo "Installing TYPO3 v14 with nr_passkeys_fe extension..."
echo ""

# Ensure proper ownership of installation directory (volume may be root-owned initially)
echo "Creating installation directory..."
sudo chown -R "$(id -u):$(id -g)" "$INSTALL_DIR" 2>/dev/null || true
rm -rf "$INSTALL_DIR"/* "$INSTALL_DIR"/.[!.]* 2>/dev/null || true
mkdir -p "$INSTALL_DIR"

# Create database
echo "Setting up database..."
mysql -h db -u root -p"root" -e "DROP DATABASE IF EXISTS ${VERSION};"
mysql -h db -u root -p"root" -e "CREATE DATABASE ${VERSION};"

# Bootstrap composer project
echo "Bootstrapping composer project..."
cd "$INSTALL_DIR"
echo "{}" > composer.json
composer config extra.typo3/cms.web-dir public -d "$INSTALL_DIR"
composer config --no-plugins allow-plugins.typo3/cms-composer-installers true -d "$INSTALL_DIR"
composer config --no-plugins allow-plugins.typo3/class-alias-loader true -d "$INSTALL_DIR"
composer config minimum-stability dev -d "$INSTALL_DIR"
composer config prefer-stable true -d "$INSTALL_DIR"

# Add path repositories for local extensions
composer config repositories.nr_passkeys_be path "$BE_EXTENSION_PATH" -d "$INSTALL_DIR"
composer config repositories.nr_passkeys_fe path "$FE_EXTENSION_PATH" -d "$INSTALL_DIR"

# Install TYPO3 v14 with both extensions + felogin for demo
# t3/cms has no v14 release - use typo3/minimal + additional packages
composer req typo3/minimal:'^14' typo3/cms-install:'^14' typo3/cms-fluid-styled-content:'^14' typo3/cms-rte-ckeditor:'^14' typo3/cms-felogin:'^14' netresearch/nr-passkeys-be:'*@dev' netresearch/nr-passkeys-fe:'*@dev' --no-progress -n -d "$INSTALL_DIR"
composer req typo3/cms-extensionmanager --no-progress -n -d "$INSTALL_DIR"
composer req --dev typo3/cms-styleguide --no-progress -n -d "$INSTALL_DIR"

# Introduction Package may not support latest TYPO3 v14 - install if available
INTRO_INSTALLED=false
if composer req typo3/cms-introduction --no-progress -n -d "$INSTALL_DIR" 2>/dev/null; then
    INTRO_INSTALLED=true
else
    echo "Note: typo3/cms-introduction not available for TYPO3 v14 - skipping demo content"
fi

# Setup TYPO3
echo "Running TYPO3 setup..."
vendor/bin/typo3 setup -n \
    --dbname="$VERSION" \
    --password=root \
    --create-site="$SITE_URL" \
    --admin-user-password="$TYPO3_SETUP_ADMIN_PASSWORD"

# Write all configuration directly to additional.php
echo "Configuring development settings..."
mkdir -p "$INSTALL_DIR/config/system"
cat > "$INSTALL_DIR/config/system/additional.php" << 'ADDITIONALPHP'
<?php
$GLOBALS['TYPO3_CONF_VARS']['BE']['debug'] = true;
$GLOBALS['TYPO3_CONF_VARS']['FE']['debug'] = true;
$GLOBALS['TYPO3_CONF_VARS']['SYS']['devIPmask'] = '*';
$GLOBALS['TYPO3_CONF_VARS']['SYS']['displayErrors'] = 1;
$GLOBALS['TYPO3_CONF_VARS']['MAIL']['transport'] = 'smtp';
$GLOBALS['TYPO3_CONF_VARS']['MAIL']['transport_smtp_server'] = 'localhost:1025';
$GLOBALS['TYPO3_CONF_VARS']['MAIL']['defaultMailFromAddress'] = 'admin@example.com';
$GLOBALS['TYPO3_CONF_VARS']['GFX']['processor'] = 'ImageMagick';
$GLOBALS['TYPO3_CONF_VARS']['GFX']['processor_path'] = '/usr/bin/';
$GLOBALS['TYPO3_CONF_VARS']['SYS']['trustedHostsPattern'] = '.*';
$GLOBALS['TYPO3_CONF_VARS']['SYS']['features']['security.backend.enforceReferrer'] = false;
ADDITIONALPHP

# Setup extensions
vendor/bin/typo3 extension:setup

# --- SITE CONFIGURATION ---
# Detect introduction package (file-based site config in TYPO3 v13+)
INTRO_ROOT=""
if [ -f config/sites/introduction/config.yaml ]; then
    INTRO_ROOT=$(grep -oP 'rootPageId:\s*\K\d+' config/sites/introduction/config.yaml 2>/dev/null || echo "")
fi

if [ -n "$INTRO_ROOT" ] && [ "$INTRO_ROOT" != "0" ]; then
    echo "Introduction package installed (rootPageId=$INTRO_ROOT). Consolidating sites..."
    rm -rf config/sites/main
    cat > config/sites/introduction/config.yaml << SITEYAML
base: '${SITE_URL}/'
errorHandling: {}
languages:
  - title: English
    enabled: true
    languageId: 0
    base: /
    typo3Language: default
    locale: en_US.UTF-8
    iso-639-1: en
    navigationTitle: English
    hreflang: en-US
    flag: us
rootPageId: ${INTRO_ROOT}
websiteTitle: 'EXT:nr_passkeys_fe Demo (v14)'
dependencies:
  - bootstrap-package/full
settings:
  nr_passkeys_fe:
    enforcement: 'off'
SITEYAML
    DEMO_PID=$INTRO_ROOT
else
    echo "No introduction package. Setting up main site with our page template..."
    # Update main site config with passkey settings
    cat > config/sites/main/config.yaml << SITEYAML
base: '${SITE_URL}/'
errorHandling: {}
languages:
  - title: English
    enabled: true
    languageId: 0
    base: /
    locale: en_US.UTF-8
    navigationTitle: English
    flag: us
rootPageId: 1
websiteTitle: 'EXT:nr_passkeys_fe Demo (v14)'
dependencies:
  - typo3/fluid-styled-content
  - typo3/fluid-styled-content-css
settings:
  nr_passkeys_fe:
    enforcement: 'off'
SITEYAML

    # Create sys_template on root page for rendering (no Bootstrap Package = use our Page template)
    mysql -h db -u root -proot "$VERSION" -e "
    INSERT INTO sys_template (pid, title, root, clear, include_static_file, config)
    VALUES (1, 'Main Template', 1, 3,
      'EXT:fluid_styled_content/Configuration/TypoScript/,EXT:nr_passkeys_fe/Configuration/TypoScript',
      'page = PAGE
page.10 = FLUIDTEMPLATE
page.10 {
  templateRootPaths.10 = EXT:nr_passkeys_fe/Resources/Private/Templates/Page/
  partialRootPaths.10 = EXT:nr_passkeys_fe/Resources/Private/Partials/
  layoutRootPaths.10 = EXT:nr_passkeys_fe/Resources/Private/Layouts/
  templateName = Default
  variables {
    content < styles.content.get
  }
}
');
    "
    # Welcome content on root page
    mysql -h db -u root -proot "$VERSION" -e "
    UPDATE pages SET title = 'EXT:nr_passkeys_fe Demo' WHERE uid = 1;
    INSERT INTO tt_content (pid, CType, header, bodytext, sorting)
    VALUES (1, 'text', 'Welcome', '<p>This is the <strong>nr_passkeys_fe</strong> development environment for TYPO3 v14.</p><p>Use the navigation above to test passkey login, enrollment, and management.</p><p><strong>FE User:</strong> demo / demo<br><strong>BE Admin:</strong> admin / Joh316!!</p>', 100);
    "
    DEMO_PID=1
fi

# Generate styleguide demo content
vendor/bin/typo3 styleguide:generate --create || echo "Styleguide generation skipped"

# Import demo pages and test FE user from fixture file
DEMO_SQL="$FE_EXTENSION_PATH/.ddev/data/demo-pages.sql"
echo "Importing demo pages and test FE user (under pid=$DEMO_PID)..."
if [ -f "$DEMO_SQL" ]; then
    sed "s/@DEMO_PID@/$DEMO_PID/g" "$DEMO_SQL" | mysql -h db -u root -p"root" "$VERSION"
    echo "Demo pages imported."
else
    echo "WARNING: $DEMO_SQL not found — skipping demo page import"
fi

# Add version-specific plugin content elements (v14 uses CType directly, no list_type)
echo "Adding plugin content elements..."
mysql -h db -u root -p"root" "$VERSION" << 'PLUGINSQL'
SET @login_page = (SELECT uid FROM pages WHERE slug='/passkey-login' LIMIT 1);
SET @passkey_only_page = (SELECT uid FROM pages WHERE slug='/passkey-only' LIMIT 1);
SET @account_page = (SELECT uid FROM pages WHERE slug='/my-account' LIMIT 1);
SET @enrollment_page = (SELECT uid FROM pages WHERE slug='/passkey-setup' LIMIT 1);

-- felogin with passkey button injected via template override
-- pages = SysFolder UID so felogin can find fe_users records
SET @fe_storage = (SELECT uid FROM pages WHERE slug='/fe-users-storage' LIMIT 1);
INSERT INTO tt_content (pid, CType, header, sorting, tstamp, crdate, pages, `recursive`)
VALUES (@login_page, 'felogin_login', 'Login', 100, UNIX_TIMESTAMP(), UNIX_TIMESTAMP(), @fe_storage, 1);

-- Passkey-only login (standalone plugin, no felogin fallback)
INSERT INTO tt_content (pid, CType, header, sorting, tstamp, crdate)
VALUES (@passkey_only_page, 'nrpasskeysfe_passkeylogin', 'Passkey-Only Login', 100, UNIX_TIMESTAMP(), UNIX_TIMESTAMP());

-- Passkey management
INSERT INTO tt_content (pid, CType, header, sorting, tstamp, crdate)
VALUES (@account_page, 'nrpasskeysfe_passkeymanagement', 'My Passkeys', 100, UNIX_TIMESTAMP(), UNIX_TIMESTAMP());

-- Passkey enrollment
INSERT INTO tt_content (pid, CType, header, sorting, tstamp, crdate)
VALUES (@enrollment_page, 'nrpasskeysfe_passkeyenrollment', 'Set Up Passkey', 100, UNIX_TIMESTAMP(), UNIX_TIMESTAMP());
PLUGINSQL

# Set felogin FlexForm (storagePid) via PHP/PDO to avoid shell quote stripping
echo "Configuring felogin storage PID..."
php "$FE_EXTENSION_PATH/.ddev/data/fix-felogin-flexform.php" "$VERSION"

# TypoScript includes
cat >> "$INSTALL_DIR/config/system/additional.php" << 'TSPHP'

\TYPO3\CMS\Core\Utility\ExtensionManagementUtility::addTypoScriptSetup(
    '@import "EXT:nr_passkeys_fe/Configuration/TypoScript/setup.typoscript"'
);
\TYPO3\CMS\Core\Utility\ExtensionManagementUtility::addTypoScriptConstants(
    '@import "EXT:nr_passkeys_fe/Configuration/TypoScript/constants.typoscript"'
);
TSPHP

# Dynamic page UID constants
LOGIN_UID=$(mysql -h db -u root -proot "$VERSION" -N -e "SELECT uid FROM pages WHERE slug='/passkey-login' LIMIT 1")
ACCOUNT_UID=$(mysql -h db -u root -proot "$VERSION" -N -e "SELECT uid FROM pages WHERE slug='/my-account' LIMIT 1")
ENROLLMENT_UID=$(mysql -h db -u root -proot "$VERSION" -N -e "SELECT uid FROM pages WHERE slug='/passkey-setup' LIMIT 1")

cat >> "$INSTALL_DIR/config/system/additional.php" << CONSTPHP

\\TYPO3\\CMS\\Core\\Utility\\ExtensionManagementUtility::addTypoScriptConstants('
plugin.tx_nrpasskeysfe.settings.loginPageUid = ${LOGIN_UID}
plugin.tx_nrpasskeysfe.settings.managementPageUid = ${ACCOUNT_UID}
plugin.tx_nrpasskeysfe.settings.enrollmentPageUid = ${ENROLLMENT_UID}
');
CONSTPHP

# Add TypoScript to sys_template (if not already done for no-intro case)
mysql -h db -u root -proot "$VERSION" -N -e "
UPDATE sys_template
SET include_static_file = CONCAT(include_static_file, ',EXT:nr_passkeys_fe/Configuration/TypoScript')
WHERE include_static_file NOT LIKE '%nr_passkeys_fe%'
LIMIT 1;
"

vendor/bin/typo3 cache:flush

echo ""
echo "========================================"
echo " TYPO3 $VERSION installation complete!"
echo "========================================"
echo ""
echo "  Frontend: ${SITE_URL}/"
echo "  Backend:  ${SITE_URL}/typo3/"
echo ""
echo "  Demo pages:"
echo "    /passkey-login  - Combined: passkey first + password fallback"
echo "    /passkey-only   - Passkey-only login (no password fallback)"
echo "    /my-account     - Passkey management (requires login)"
echo "    /passkey-setup  - Passkey enrollment"
echo ""
echo "  FE User: demo / demo"
echo "  BE Admin: admin / Joh316!!"
