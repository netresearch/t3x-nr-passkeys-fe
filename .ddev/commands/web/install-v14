#!/bin/bash

## Description: Install TYPO3 14.x with nr_passkeys_fe extension
## Usage: install-v14
## Example: ddev install-v14

set -e

VERSION=v14
INSTALL_DIR="/var/www/html/$VERSION"
FE_EXTENSION_PATH="/var/www/nr_passkeys_fe"
BE_EXTENSION_PATH="/var/www/nr_passkeys_be"

echo "Installing TYPO3 v14 with nr_passkeys_fe extension..."
echo ""

# Ensure proper ownership of installation directory (volume may be root-owned initially)
echo "Creating installation directory..."
sudo chown -R "$(id -u):$(id -g)" "$INSTALL_DIR" 2>/dev/null || true
rm -rf "$INSTALL_DIR"/* "$INSTALL_DIR"/.[!.]* 2>/dev/null || true
mkdir -p "$INSTALL_DIR"

# Create database
echo "Setting up database..."
mysql -h db -u root -p"root" -e "DROP DATABASE IF EXISTS ${VERSION};"
mysql -h db -u root -p"root" -e "CREATE DATABASE ${VERSION};"

# Bootstrap composer project
echo "Bootstrapping composer project..."
cd "$INSTALL_DIR"
echo "{}" > composer.json
composer config extra.typo3/cms.web-dir public -d "$INSTALL_DIR"
composer config --no-plugins allow-plugins.typo3/cms-composer-installers true -d "$INSTALL_DIR"
composer config --no-plugins allow-plugins.typo3/class-alias-loader true -d "$INSTALL_DIR"
composer config minimum-stability dev -d "$INSTALL_DIR"
composer config prefer-stable true -d "$INSTALL_DIR"

# Add path repositories for local extensions
composer config repositories.nr_passkeys_be path "$BE_EXTENSION_PATH" -d "$INSTALL_DIR"
composer config repositories.nr_passkeys_fe path "$FE_EXTENSION_PATH" -d "$INSTALL_DIR"

# Install TYPO3 v14 with both extensions + felogin for demo
# t3/cms has no v14 release - use typo3/minimal + additional packages
composer req typo3/minimal:'^14' typo3/cms-install:'^14' typo3/cms-fluid-styled-content:'^14' typo3/cms-rte-ckeditor:'^14' typo3/cms-felogin:'^14' netresearch/nr-passkeys-be:'*@dev' netresearch/nr-passkeys-fe:'*@dev' --no-progress -n -d "$INSTALL_DIR"
composer req typo3/cms-extensionmanager --no-progress -n -d "$INSTALL_DIR"
composer req --dev typo3/cms-styleguide --no-progress -n -d "$INSTALL_DIR"

# Introduction Package may not support latest TYPO3 v14 - install if available
if composer req typo3/cms-introduction --no-progress -n -d "$INSTALL_DIR" 2>/dev/null; then
    INTRO_INSTALLED=true
else
    echo "Note: typo3/cms-introduction not available for TYPO3 v14 - skipping demo content"
    INTRO_INSTALLED=false
fi

# Setup TYPO3
echo "Running TYPO3 setup..."
vendor/bin/typo3 setup -n \
    --dbname="$VERSION" \
    --password=root \
    --create-site="https://${VERSION}.nr-passkeys-fe.ddev.site" \
    --admin-user-password="$TYPO3_SETUP_ADMIN_PASSWORD"

# Write all configuration directly to additional.php (configuration:set removed in v14)
echo "Configuring development settings..."
mkdir -p "$INSTALL_DIR/config/system"
cat > "$INSTALL_DIR/config/system/additional.php" << 'ADDITIONALPHP'
<?php
// Development settings
$GLOBALS['TYPO3_CONF_VARS']['BE']['debug'] = true;
$GLOBALS['TYPO3_CONF_VARS']['FE']['debug'] = true;
$GLOBALS['TYPO3_CONF_VARS']['SYS']['devIPmask'] = '*';
$GLOBALS['TYPO3_CONF_VARS']['SYS']['displayErrors'] = 1;

// Mail configuration (Mailpit)
$GLOBALS['TYPO3_CONF_VARS']['MAIL']['transport'] = 'smtp';
$GLOBALS['TYPO3_CONF_VARS']['MAIL']['transport_smtp_server'] = 'localhost:1025';
$GLOBALS['TYPO3_CONF_VARS']['MAIL']['defaultMailFromAddress'] = 'admin@example.com';

// Graphics
$GLOBALS['TYPO3_CONF_VARS']['GFX']['processor'] = 'ImageMagick';
$GLOBALS['TYPO3_CONF_VARS']['GFX']['processor_path'] = '/usr/bin/';

// Security settings for DDEV multi-subdomain environment
$GLOBALS['TYPO3_CONF_VARS']['SYS']['trustedHostsPattern'] = '.*';
$GLOBALS['TYPO3_CONF_VARS']['SYS']['features']['security.backend.enforceReferrer'] = false;
ADDITIONALPHP

# Enable deprecation log if settings.php exists
if [ -f "$INSTALL_DIR/config/system/settings.php" ]; then
    sed -i "/'deprecations'/,/^[[:space:]]*'disabled' => true,/s/'disabled' => true,/'disabled' => false,/" "$INSTALL_DIR/config/system/settings.php"
fi

# Setup extensions
vendor/bin/typo3 extension:setup

# Configure site sets for v14 (only if Bootstrap Package is available via introduction)
if [ "$INTRO_INSTALLED" = "true" ] && [ -f config/sites/main/config.yaml ]; then
    if ! grep -q "^dependencies:" config/sites/main/config.yaml; then
        echo "" >> config/sites/main/config.yaml
        echo "dependencies:" >> config/sites/main/config.yaml
        echo "  - bootstrap-package/full" >> config/sites/main/config.yaml
        echo "Site sets configured with Bootstrap Package"
    fi
fi

# Generate styleguide demo content
vendor/bin/typo3 styleguide:generate || echo "Styleguide generation skipped"

# Create demo pages with passkey plugins and test FE user
echo "Creating demo pages and test FE user..."
vendor/bin/typo3 sql:query "$(cat <<'SQL'
INSERT IGNORE INTO pages (uid, pid, title, slug, doktype, is_siteroot, sorting)
VALUES (100, 1, 'FE Users', '/fe-users', 254, 0, 512);

INSERT IGNORE INTO fe_groups (uid, pid, title, passkey_enforcement)
VALUES (1, 100, 'Demo Users', 'off');

INSERT IGNORE INTO fe_users (uid, pid, username, password, usergroup, email, name, disable)
VALUES (1, 100, 'demo', '\$2y\$12\$LY9RNkX4W2v9FpA3K1vK1eFQfSj5QrGT0mQJ6cGhKfGdNx1t6sYZO', '1', 'demo@example.com', 'Demo User', 0);

INSERT IGNORE INTO pages (uid, pid, title, slug, doktype, sorting)
VALUES (10, 1, 'Login', '/login', 1, 100);

INSERT IGNORE INTO pages (uid, pid, title, slug, doktype, sorting, fe_group)
VALUES (11, 1, 'My Account', '/my-account', 1, 200, '-2');

INSERT IGNORE INTO pages (uid, pid, title, slug, doktype, sorting)
VALUES (12, 1, 'Passkey Setup', '/passkey-setup', 1, 300);

INSERT IGNORE INTO tt_content (uid, pid, CType, list_type, header, sorting)
VALUES (10, 10, 'login', '', 'Frontend Login', 100);

INSERT IGNORE INTO tt_content (uid, pid, CType, list_type, header, sorting)
VALUES (11, 10, 'list', 'nrpasskeysfe_passkeylogin', 'Passkey Login', 200);

INSERT IGNORE INTO tt_content (uid, pid, CType, list_type, header, sorting)
VALUES (12, 11, 'list', 'nrpasskeysfe_passkeymanagement', 'My Passkeys', 100);

INSERT IGNORE INTO tt_content (uid, pid, CType, list_type, header, sorting)
VALUES (13, 12, 'list', 'nrpasskeysfe_passkeyenrollment', 'Set Up Passkey', 100);
SQL
)" || echo "Demo data creation skipped (may already exist)"

if [ -f config/sites/main/config.yaml ]; then
    if ! grep -q "nr_passkeys_fe:" config/sites/main/config.yaml; then
        cat >> config/sites/main/config.yaml << 'SITECFG'

settings:
  nr_passkeys_fe:
    enforcement: 'off'
SITECFG
    fi
fi

cat >> "$INSTALL_DIR/config/system/additional.php" << 'TSPHP'

\TYPO3\CMS\Core\Utility\ExtensionManagementUtility::addTypoScriptSetup(
    '@import "EXT:nr_passkeys_fe/Configuration/TypoScript/setup.typoscript"'
);
\TYPO3\CMS\Core\Utility\ExtensionManagementUtility::addTypoScriptConstants(
    '@import "EXT:nr_passkeys_fe/Configuration/TypoScript/constants.typoscript"'
);
\TYPO3\CMS\Core\Utility\ExtensionManagementUtility::addTypoScriptConstants('
plugin.tx_nrpasskeysfe.settings.loginPageUid = 10
plugin.tx_nrpasskeysfe.settings.managementPageUid = 11
plugin.tx_nrpasskeysfe.settings.enrollmentPageUid = 12
');
TSPHP

vendor/bin/typo3 cache:flush

echo ""
echo "========================================"
echo " TYPO3 $VERSION installation complete!"
echo "========================================"
echo ""
echo "  Frontend: https://v14.nr-passkeys-fe.ddev.site/"
echo "  Backend:  https://v14.nr-passkeys-fe.ddev.site/typo3/"
echo ""
echo "  Demo pages:"
echo "    /login          - Login page (felogin + passkey plugin)"
echo "    /my-account     - Passkey management (requires login)"
echo "    /passkey-setup  - Passkey enrollment"
echo ""
echo "  FE User: demo / password"
echo "  BE Admin: admin / Joh316!!"
